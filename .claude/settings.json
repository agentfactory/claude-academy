{
  "permissions": {
    "allow": [
      "Bash(curl https://backend.blotato.com/*)",
      "Bash(jq *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-post.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
